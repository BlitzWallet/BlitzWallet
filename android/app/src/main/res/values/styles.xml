<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:editTextBackground">@mipmap/rn_edit_text_material</item>
        <item name="android:windowBackground">@color/colorAccent</item>
        <!-- <item name="android:colorBackground">@android:color/transparent</item> -->
    </style>

    <!-- Android 12+ SplashScreen API (backported via androidx.core:core-splashscreen).
         Set on .MainActivity; postSplashScreenTheme reverts to AppTheme once the app loads. -->
    <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splashscreen_background</item>
        <!-- Solid window background so the brief native-splash -> first-React-frame
             handoff shows the splash color, not the system default (black on some OEMs). -->
        <item name="android:windowBackground">@color/splashscreen_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splashscreen_logo</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
        <item name="android:windowSplashScreenBehavior">icon_preferred</item>
    </style>

</resources>
